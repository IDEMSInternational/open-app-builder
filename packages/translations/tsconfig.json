    "lib": ["es6", "es2015", "dom"],
    "outDir": "lib",
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "data-models": ["../data-models"]
    }
  },
  "include": ["src/**/*.ts"]
}
